{
  "name": "farplane-web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "generate-routes": "tsr generate",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write --error-on-warnings .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bddgen && playwright test",
    "bddgen": "bddgen",
    "knip": "knip",
    "deps": "depcruise --config .dependency-cruiser.cjs --exclude 'node_modules' src",
    "audit": "bun audit --audit-level=moderate",
    "mutate": "stryker run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@uiw/codemirror-theme-github": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.14.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "qs": "6.15.3",
    "@hono/node-server": "2.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@playwright/test": "^1.61.1",
    "@rsbuild/core": "^2.1.7",
    "@rsbuild/plugin-react": "^2.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@tanstack/router-cli": "^1.132.0",
    "@tanstack/router-plugin": "latest",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^18.1.0",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "knip": "^6.29.0",
    "msw": "^2.15.0",
    "playwright-bdd": "^9.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
