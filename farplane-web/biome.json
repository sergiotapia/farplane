{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/routeTree.gen.ts",
      "!**/dist",
      "!**/coverage",
      "!**/playwright-report",
      "!**/test-results",
      "!**/.features-gen",
      "!**/reports",
      "!**/bun.lock",
      "!**/src/styles.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": false
    },
    "formatter": {
      "enabled": false
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "solid": "none",
      "next": "none"
    },
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noExcessiveCognitiveComplexity": "error",
        "noUselessStringConcat": "error",
        "noUselessUndefinedInitialization": "error",
        "useFlatMap": "error",
        "useDateNow": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error",
        "noUnusedFunctionParameters": "error",
        "useHookAtTopLevel": "error",
        "useUniqueElementIds": "off"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noBarrelFile": "off",
        "noNamespaceImport": "off",
        "noJsxPropsBind": "off"
      },
      "security": {
        "preset": "recommended",
        "noSecrets": "off"
      },
      "style": {
        "noNonNullAssertion": "error",
        "useConst": "error",
        "useTemplate": "error",
        "noUselessElse": "error",
        "useExportType": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useComponentExportOnlyModules": "off"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noDocumentCookie": "error",
        "noConsole": "off",
        "noAlert": "error",
        "noVar": "error",
        "noUnknownAttribute": "error",
        "noLeakedRender": "error",
        "noSkippedTests": "error",
        "useAwait": "error"
      },
      "a11y": {
        "preset": "recommended",
        "useSemanticElements": "error",
        "useKeyWithClickEvents": "error",
        "noLabelWithoutControl": "error",
        "noSvgWithoutTitle": "error"
      },
      "nursery": {
        "noMisusedPromises": "error",
        "noFloatingPromises": "error",
        "useSortedClasses": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/components/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noSvgWithoutTitle": "off",
            "useSemanticElements": "off",
            "useKeyWithClickEvents": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          },
          "suspicious": {
            "noDocumentCookie": "off",
            "noLeakedRender": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/routes/**",
        "src/components/lanes/**",
        "src/components/navigation/**"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.{test,spec}.{ts,tsx}", "e2e/**", "src/test/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "warn",
            "noSkippedTests": "off",
            "noAlert": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "nursery": {
            "noFloatingPromises": "off",
            "noMisusedPromises": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
