# Local development defaults (copy to .env if you want to override).
# The API loads .env from the repo root or farplane-backend/ (does not override
# variables already set in the shell).
APP_ENV=local
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/farplane_dev?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/farplane_test?sslmode=disable
ADDR=:8080

# SPA origin used after Google OAuth redirects.
APP_BASE_URL=http://localhost:3000
# Public URL of this API (GitHub App Manifest webhooks/callbacks).
# Must NOT be localhost when creating the GitHub App — use ngrok https URL.
APP_API_BASE_URL=http://localhost:8080

# Session cookie (HttpOnly, SameSite=Lax, path=/). Secure=false for local HTTP.
SESSION_COOKIE_SECURE=false
# Signs Google OAuth state. Required outside local/dev (defaults in local/dev only).
SESSION_SECRET=farplane-local-session-secret-change-me

# Google OAuth (optional). When unset, password setup still works; Google start returns 503.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Optional bootstrap secret for first-time setup. When set, /setup requires it
# (body setup_token or header X-Farplane-Setup-Token). Recommended for any
# install reachable beyond localhost.
# SETUP_TOKEN=

# Lane computer backend: docker (default). Sprites later.
# RUNTIME=docker

# GitHub App (optional env override). Prefer Settings → Create Farplane GitHub App
# (manifest flow); credentials are then stored encrypted in Postgres.
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=farplane
# GITHUB_APP_PRIVATE_KEY=      # PEM; use \n for newlines, or set GITHUB_APP_PRIVATE_KEY_PATH
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_APP_CALLBACK_URL=http://localhost:8080/api/v1/github/callback
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
