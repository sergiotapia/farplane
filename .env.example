# Local development defaults (copy to .env if you want to override).
APP_ENV=local
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/farplane_dev?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/farplane_test?sslmode=disable
ADDR=:8080

# SPA origin used after Google OAuth redirects.
APP_BASE_URL=http://localhost:3000

# Session cookie (HttpOnly, SameSite=Lax, path=/). Secure=false for local HTTP.
SESSION_COOKIE_SECURE=false
# Signs Google OAuth state. Required outside local/dev (defaults in local/dev only).
SESSION_SECRET=farplane-local-session-secret-change-me

# Google OAuth (optional). When unset, password setup still works; Google start returns 503.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Optional bootstrap secret for first-time setup. When set, /setup requires it
# (body setup_token or header X-Farplane-Setup-Token). Recommended for any
# install reachable beyond localhost.
# SETUP_TOKEN=
